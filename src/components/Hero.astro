---
import DucLogo from './DucLogo.astro';
import { ctaHref } from '../utils/url';
import hero from '../data/hero.json';

interface Props {
  isStandalone?: boolean;
}
const { isStandalone = false } = Astro.props;

const primaryHref = ctaHref(hero.ctaPrimary.href, isStandalone)!;
const secondaryHref = ctaHref(hero.ctaSecondary.href, isStandalone)!;
---
<section class="hero" id="home">
  <div class="hero-content">
    <div class="logo-container">
      <div class="logo-bubbles">
        <span></span><span></span><span></span><span></span><span></span>
        <span></span><span></span><span></span><span></span><span></span>
      </div>
      <DucLogo class="hero-logo" />
    </div>
    <h1>{hero.titleLine1}<span>{hero.titleLine2}</span></h1>
    <p>{hero.tagline}</p>
    <div class="cta-buttons">
      <a href={primaryHref} class="btn btn-primary">{hero.ctaPrimary.text}</a>
      <a href={secondaryHref} class="btn btn-secondary">{hero.ctaSecondary.text}</a>
    </div>
  </div>
  <div class="scroll-indicator">
    <svg viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/></svg>
  </div>
</section>
