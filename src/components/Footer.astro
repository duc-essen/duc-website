---
import { getCollection } from 'astro:content';

const vorstand = (await getCollection('vorstand')).sort(
  (a, b) => a.data.order - b.data.order
);
---
<footer>
  <div class="footer-content">
    <div class="footer-section">
      <h4>DUC Essen</h4>
      <p>Deutscher Unterwasserclub Essen e.V.<br>Trägerverein des Landesleistungsstützpunktes NRW für Freitauchen</p>
      <p style="margin-top: 1rem;"><strong>Postanschrift:</strong><br>Postfach 34 01 51<br>45073 Essen</p>
    </div>
    <div class="footer-section">
      <h4>Vorstand</h4>
      {vorstand.map((person) => (
        <p>{person.data.rolle}: {person.data.name}</p>
      ))}
    </div>
    <div class="footer-section">
      <h4>Quick Links</h4>
      <a href="#home">Start</a>
      <a href="#angebote">Angebote</a>
      <a href="#training">Training</a>
      <a href="#geschichte">Geschichte</a>
      <a href="#veranstaltungen">Events</a>
      <a href="#preise">Preise</a>
      <a href="#kontakt">Kontakt</a>
    </div>
    <div class="footer-section">
      <h4>Impressum</h4>
      <p>Deutscher Unterwasserclub Essen e.V.</p>
      <p>Registergericht: Amtsgericht Essen</p>
      <p>Registernummer: VR 1507</p>
      <a href="https://duc-essen.de/datenschutzhinweise/" target="_blank" style="margin-top: 1rem; display: inline-block;">Datenschutz</a>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; <span id="currentYear"></span> Deutscher Unterwasserclub Essen e.V. - Alle Rechte vorbehalten</p>
  </div>
</footer>
