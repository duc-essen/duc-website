---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  section: CollectionEntry<'sections'>;
  isStandalone?: boolean;
}
const { section } = Astro.props;

const items = (await getCollection('mitgliedschaften')).sort(
  (a, b) => a.data.order - b.data.order
);

// Logos werden zur Build-Zeit per Vite-Glob gefunden + von Astro zu WebP
// optimiert. Frontmatter gibt nur den Filename an (z.B. "tsvnrw.png").
const logos = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/mitgliedschaften/*.{png,jpg,jpeg,webp,svg}',
  { eager: true }
);
function resolveLogo(filename: string): ImageMetadata {
  const entry = Object.entries(logos).find(([path]) => path.endsWith('/' + filename));
  if (!entry) {
    throw new Error(
      `Mitgliedschaft-Logo "${filename}" nicht in src/assets/mitgliedschaften/ gefunden.`
    );
  }
  return entry[1].default;
}
---
<section class="mitgliedschaften" id={section.id}>
  <p class="mitgliedschaften-heading">{section.data.title}</p>
  <div class="mitgliedschaften-grid">
    {items.map((item) => (
      <a href={item.data.url} target="_blank" rel="noopener" class="mitgliedschaft-card">
        <div class="mitgliedschaft-card-inner">
          <div class="mitgliedschaft-logo-wrap">
            <Image
              src={resolveLogo(item.data.logoUrl)}
              alt={item.data.name}
              loading="lazy"
              widths={[280]}
              sizes="140px"
              format="webp"
              class="mitgliedschaft-logo"
            />
          </div>
          <div class="mitgliedschaft-name">{item.data.name}</div>
          <div class="mitgliedschaft-sub">{item.data.untertitel}</div>
        </div>
      </a>
    ))}
  </div>
  {section.data.mitgliedschaften_footer && (
    <p class="mitgliedschaften-footer">{section.data.mitgliedschaften_footer}</p>
  )}
</section>

<style>
  .mitgliedschaften {
    background: var(--gray-light);
    padding: 3rem 5%;
    text-align: center;
  }
  .mitgliedschaften-heading {
    color: var(--gray);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 2px;
  }
  .mitgliedschaften-grid {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
    max-width: 900px;
    margin: 0 auto;
  }
  .mitgliedschaft-card {
    text-decoration: none;
    transition: transform 0.3s ease;
    display: inline-block;
  }
  .mitgliedschaft-card:hover {
    transform: scale(1.05);
  }
  .mitgliedschaft-card-inner {
    background: white;
    padding: 1.5rem 2rem;
    border-radius: 10px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    text-align: center;
    width: 220px;
    box-sizing: border-box;
  }
  .mitgliedschaft-logo-wrap {
    height: 50px;
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .mitgliedschaft-logo {
    max-height: 50px;
    max-width: 140px;
    width: auto;
    height: auto;
    object-fit: contain;
  }
  .mitgliedschaft-name {
    font-weight: 700;
    color: var(--blue);
    font-size: 1.3rem;
  }
  .mitgliedschaft-sub {
    font-size: 0.75rem;
    color: var(--gray);
  }
  .mitgliedschaften-footer {
    color: var(--blue);
    font-weight: 600;
    margin-top: 1.5rem;
    font-size: 0.95rem;
  }
</style>
