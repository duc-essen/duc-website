---
import type { CollectionEntry } from 'astro:content';
import Angebote from './Angebote.astro';
import Training from './Training.astro';
import Geschichte from './Geschichte.astro';
import Veranstaltungen from './Veranstaltungen.astro';
import Preise from './Preise.astro';
import Kontakt from './Kontakt.astro';
import Mitgliedschaften from './Mitgliedschaften.astro';

/**
 * Dispatch-Map: section.id → konkrete Komponente.
 * Wenn du eine neue Sektion hinzufuegst, hier einen Eintrag ergaenzen.
 */
const COMPONENTS = {
  angebote: Angebote,
  training: Training,
  geschichte: Geschichte,
  veranstaltungen: Veranstaltungen,
  preise: Preise,
  kontakt: Kontakt,
  mitgliedschaften: Mitgliedschaften,
} as const;

type SectionId = keyof typeof COMPONENTS;

interface Props {
  section: CollectionEntry<'sections'>;
  isStandalone?: boolean;
}
const { section, isStandalone = false } = Astro.props;

const Component = COMPONENTS[section.id as SectionId];

if (!Component) {
  throw new Error(
    `SectionRenderer: keine Komponente fuer section.id="${section.id}" registriert. ` +
      `Ergaenze SectionRenderer.astro um einen Eintrag in COMPONENTS.`
  );
}
---
<Component section={section} isStandalone={isStandalone} />
