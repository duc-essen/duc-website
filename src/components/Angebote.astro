---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import AngebotIcon from './icons/AngebotIcon.astro';
import { ctaHref } from '../utils/url';

interface Props {
  section: CollectionEntry<'sections'>;
  isStandalone?: boolean;
}
const { section, isStandalone = false } = Astro.props;

const angebote = (await getCollection('angebote')).sort(
  (a, b) => a.data.order - b.data.order
);
const rendered = await Promise.all(
  angebote.map(async (a) => ({ entry: a, Content: (await render(a)).Content }))
);

const ctaLink = ctaHref(section.data.cta?.href, isStandalone);
---
<section class="features" id={section.id}>
  <div class="section-title">
    <h2>{section.data.title}</h2>
    {section.data.subtitle && <p>{section.data.subtitle}</p>}
  </div>
  <div class="features-grid">
    {rendered.map(({ entry, Content }) => (
      <div class="feature-card fade-in">
        <div class="feature-icon"><AngebotIcon name={entry.data.icon} /></div>
        <h3>{entry.data.titel}</h3>
        <div class="card-text"><Content /></div>
      </div>
    ))}
  </div>
  {section.data.cta && ctaLink && (
    <div style="text-align: center; margin-top: 3rem;">
      <a href={ctaLink} class="btn btn-primary">{section.data.cta.text}</a>
    </div>
  )}
</section>

<style>
  .card-text :global(p) {
    color: var(--gray);
    margin: 0;
  }
</style>
