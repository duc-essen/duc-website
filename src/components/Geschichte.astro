---
import { getCollection, render } from 'astro:content';
import TimelineIcon from './icons/TimelineIcon.astro';

const entries = (await getCollection('geschichte')).sort(
  (a, b) => a.data.order - b.data.order
);
const rendered = await Promise.all(
  entries.map(async (entry) => ({ entry, Content: (await render(entry)).Content }))
);
---
<section class="geschichte" id="geschichte">
  <div class="section-title">
    <h2>Unsere Geschichte</h2>
    <p>Mehr als 60 Jahre Leidenschaft für den Unterwassersport</p>
  </div>
  <div class="timeline">
    {rendered.map(({ entry, Content }) => (
      <div class="timeline-item fade-in">
        <div class={`timeline-card${entry.data.highlight ? ' timeline-highlight' : ''}`}>
          <div class="timeline-header">
            <span class="timeline-icon"><TimelineIcon name={entry.data.icon} /></span>
            <span class="timeline-year">{entry.data.jahr}</span>
          </div>
          <div class="timeline-title">{entry.data.titel}</div>
          <div class="timeline-text"><Content /></div>
        </div>
      </div>
    ))}
  </div>
  <div style="text-align: center; margin-top: 2rem;">
    <a href="#kontakt" class="btn btn-primary">Werde Teil unserer Geschichte</a>
  </div>
</section>
