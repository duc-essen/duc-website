---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import CtaButton from './CtaButton.astro';

interface Props {
  section: CollectionEntry<'sections'>;
  isStandalone?: boolean;
}
const { section, isStandalone = false } = Astro.props;

if (!section.data.training) {
  throw new Error(
    `Section "${section.id}" wird mit der Training-Komponente gerendert, ` +
      `hat aber keinen "training"-Frontmatter-Block in src/content/sections/${section.id}.md.`
  );
}
const t = section.data.training;

// Trainings-Bilder werden zur Build-Zeit per Vite-Glob gefunden + von Astro
// optimiert (Format-Konvertierung, Responsive, Lazy). Frontmatter im Markdown
// gibt nur den Filename an (`/images/training/training-1.jpg`), Lookup hier.
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/training/*.{jpg,jpeg,png,webp,avif}',
  { eager: true }
);
function resolveImage(url: string): ImageMetadata | null {
  const filename = url.split('/').pop();
  if (!filename) return null;
  const found = Object.entries(allImages).find(([path]) => path.endsWith('/' + filename));
  return found ? found[1].default : null;
}
---
<section class="training" id={section.id}>
  <div class="section-title">
    <h2>{section.data.title}</h2>
    {section.data.subtitle && <p>{section.data.subtitle}</p>}
  </div>
  <div class="training-content">
    <div class="training-info fade-in">
      <h3>{t.ort}</h3>
      <p class="training-beschreibung">{t.beschreibung}</p>
      <div class="training-schedule">
        {t.schedule.map((s) => (
          <div class="schedule-item">
            <span class="schedule-day">{s.tag}</span>
            <span class="schedule-time">{s.zeit}</span>
          </div>
        ))}
      </div>
      {section.data.cta && (
        <div class="training-cta">
          <CtaButton cta={section.data.cta} isStandalone={isStandalone} />
        </div>
      )}
    </div>
    <div class="training-visual fade-in">
      <div class="training-bilder">
        {t.bilder.map((bild) => {
          const img = resolveImage(bild.url);
          return img ? (
            <Image
              src={img}
              alt={bild.alt}
              loading="lazy"
              widths={[400, 600, 800]}
              sizes="(max-width: 768px) 100vw, 50vw"
              format="webp"
              class="training-bild"
            />
          ) : null;
        })}
      </div>
    </div>
  </div>
  <div class="training-map-wrapper">
    <iframe
      data-name="google-maps"
      data-src={t.mapEmbedUrl}
      class="training-map"
      allowfullscreen=""
      loading="lazy"
      title={`Google Maps Standort ${t.ort}`}
    />
  </div>
</section>

<style>
  .training-beschreibung {
    white-space: pre-line;
  }
  .training-cta {
    margin-top: 2rem;
  }
  .training-bilder {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .training-bild {
    width: 100%;
    border-radius: 15px;
    object-fit: cover;
    height: 180px;
    box-shadow: 0 10px 30px rgba(0, 79, 158, 0.2);
  }
  .training-map-wrapper {
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    margin-top: 2rem;
  }
  .training-map {
    width: 100%;
    height: 400px;
    border: none;
  }
</style>
