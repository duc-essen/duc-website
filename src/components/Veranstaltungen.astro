---
import { getCollection, render } from 'astro:content';
import EventIcon from './icons/EventIcon.astro';

const entries = (await getCollection('veranstaltungen')).sort(
  (a, b) => a.data.order - b.data.order
);
const rendered = await Promise.all(
  entries.map(async (entry) => ({ entry, Content: (await render(entry)).Content }))
);
---
<section class="veranstaltungen" id="veranstaltungen" style="background: var(--white);">
  <div class="section-title">
    <h2>Veranstaltungen &amp; Tipps</h2>
    <p>Spannende Events und Ausflugsziele für Taucher und Wassersportler</p>
  </div>
  <div style="max-width: 1100px; margin: 0 auto;">
    <div class="features-grid">
      {rendered.map(({ entry, Content }) => (
        <div class="feature-card fade-in" style="text-align: left; border-top: 4px solid var(--gold);">
          <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 1rem;">
            <EventIcon name={entry.data.icon} />
            <span class={`event-badge event-badge-${entry.data.badge_style}`}>{entry.data.badge_text}</span>
          </div>
          <h3 style="color: var(--blue); margin-bottom: 0.5rem;">{entry.data.titel}</h3>
          <p style="color: var(--gold); font-weight: 600; font-size: 0.9rem; margin-bottom: 1rem;">{entry.data.untertitel}</p>
          <div class="event-description"><Content /></div>
          {entry.data.infos.length > 0 && (
            <div class="event-infos">
              {entry.data.infos.map((info, i) => (
                <p style={i > 0 ? 'margin-top: 0.5rem;' : undefined}>
                  <strong>{info.label}:</strong> <Fragment set:html={info.wert} />
                </p>
              ))}
            </div>
          )}
          {entry.data.link && (
            <a href={entry.data.link.url} target="_blank" class="btn btn-primary" style="width: 100%; justify-content: center;">
              {entry.data.link.text}
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .event-badge {
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
  }
  .event-badge-gold {
    background: var(--gold);
    color: var(--blue-dark);
  }
  .event-badge-blue {
    background: var(--blue);
    color: white;
  }
  .event-description {
    color: var(--gray);
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }
  .event-description :global(p) {
    margin: 0 0 0.5rem;
  }
  .event-infos {
    background: var(--gray-light);
    padding: 1rem;
    border-radius: 10px;
    font-size: 0.9rem;
  }
</style>
