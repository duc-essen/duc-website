---
import LegalLayout from '../layouts/LegalLayout.astro';
import { getCollection } from 'astro:content';
import verein from '../data/verein.json';

const vorstand = (await getCollection('vorstand')).sort(
  (a, b) => a.data.order - b.data.order
);
const ersteVorsitzende = vorstand.find((p) => p.id === 'vorsitzende');

const title = 'Impressum';
const description = `Impressum und Anbieterkennzeichnung gemäß § 5 TMG des ${verein.name}.`;
---
<LegalLayout title={title} frontmatter={{ title, description }}>
  <h2>Angaben gemäß § 5 TMG</h2>
  <p>
    <strong>{verein.name}</strong><br />
    {verein.anschrift.postfach}<br />
    {verein.anschrift.plzOrt}<br />
    {verein.anschrift.land}
  </p>

  <h2>Kontakt</h2>
  <p>
    E-Mail: <a href={`mailto:${verein.email}`}>{verein.email}</a>
  </p>

  <h2>Vertretungsberechtigter Vorstand</h2>
  <ul>
    {vorstand.map((p) => (
      <li><strong>{p.data.rolle}:</strong> {p.data.name}</li>
    ))}
  </ul>

  <h2>Registereintrag</h2>
  <p>Eintragung im Vereinsregister.</p>
  <ul>
    <li><strong>Registergericht:</strong> {verein.registergericht}</li>
    <li><strong>Registernummer:</strong> {verein.registernummer}</li>
  </ul>

  <h2>Verantwortlich für den Inhalt nach § 18 Abs. 2 MStV</h2>
  <p>
    {ersteVorsitzende?.data.name ?? '—'}<br />
    c/o {verein.name}<br />
    {verein.anschrift.postfach}<br />
    {verein.anschrift.plzOrt}
  </p>

  <h2>Haftung für Inhalte</h2>
  <p>
    Die Inhalte unserer Seiten wurden mit größter Sorgfalt erstellt. Für die
    Richtigkeit, Vollständigkeit und Aktualität der Inhalte können wir jedoch
    keine Gewähr übernehmen. Als Diensteanbieter sind wir gemäß § 7 Abs. 1 TMG
    für eigene Inhalte auf diesen Seiten nach den allgemeinen Gesetzen
    verantwortlich. Nach §§ 8 bis 10 TMG sind wir als Diensteanbieter jedoch
    nicht verpflichtet, übermittelte oder gespeicherte fremde Informationen zu
    überwachen.
  </p>

  <h2>Haftung für Links</h2>
  <p>
    Unser Angebot enthält Links zu externen Websites Dritter, auf deren Inhalte
    wir keinen Einfluss haben. Deshalb können wir für diese fremden Inhalte auch
    keine Gewähr übernehmen. Für die Inhalte der verlinkten Seiten ist stets der
    jeweilige Anbieter oder Betreiber der Seiten verantwortlich.
  </p>

  <h2>Urheberrecht</h2>
  <p>
    Die durch die Seitenbetreiber erstellten Inhalte und Werke auf diesen Seiten
    unterliegen dem deutschen Urheberrecht. Vervielfältigung, Bearbeitung,
    Verbreitung und jede Art der Verwertung außerhalb der Grenzen des
    Urheberrechts bedürfen der schriftlichen Zustimmung des jeweiligen Autors
    bzw. Erstellers.
  </p>
</LegalLayout>
