---
import '../styles/global.css';
// Inter Variable lokal eingebunden — SIL Open Font License, von Rasmus Andersson
// unabhaengig vom Google-Oekosystem. Kein CDN-Call zu Drittanbietern.
import '@fontsource-variable/inter';
import { pathTo } from '../utils/url';
import SeoHead from '../components/SeoHead.astro';
import Bubbles from '../components/Bubbles.astro';
import BackToTop from '../components/BackToTop.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'DUC Essen - Deutscher Unterwasserclub Essen e.V.',
  description = 'DUC Essen - Dein Verein für Tauchen, Apnoe, Freediving und Flossenschwimmen in Essen. Training Di 20:00 & Do 20:15 im Stadtbad Nord-Ost. Kostenloses Probetraining!',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <SeoHead title={title} description={description} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Zum Hauptinhalt springen</a>
    <Bubbles />
    <slot />
    <BackToTop />

    <script>
      import { initLayout } from '../scripts/layout';
      initLayout();
    </script>

    <!--
      Klaro Privacy Manager — Consent-Banner.
      Lazy: erst nach Initial-Render via requestIdleCallback laden, damit die
      ~68 KB klaro.js den LCP nicht ausbremsen. Drittanbieter-Iframes
      (Maps, Vereinsplaner) sind data-name/data-src und werden erst nach
      Klaro-Init aktiviert — die kleine Verzoegerung ist unkritisch.
    -->
    <script is:inline define:vars={{ configSrc: pathTo('klaro/klaro-config.js'), klaroSrc: pathTo('klaro/klaro.js') }}>
      function loadKlaro() {
        var c = document.createElement('script');
        c.src = configSrc;
        c.onload = function () {
          var k = document.createElement('script');
          k.src = klaroSrc;
          k.setAttribute('data-config', 'klaroConfig');
          document.head.appendChild(k);
        };
        document.head.appendChild(c);
      }
      if ('requestIdleCallback' in window) {
        requestIdleCallback(loadKlaro, { timeout: 2500 });
      } else {
        window.addEventListener('load', function () { setTimeout(loadKlaro, 1200); });
      }
    </script>
  </body>
</html>
