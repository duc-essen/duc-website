---
import '../styles/global.css';
// Inter Variable lokal eingebunden — SIL Open Font License, von Rasmus Andersson
// unabhaengig vom Google-Oekosystem. Kein CDN-Call zu Drittanbietern.
import '@fontsource-variable/inter';
import { pathTo } from '../utils/url';
import SeoHead from '../components/SeoHead.astro';
import Bubbles from '../components/Bubbles.astro';
import BackToTop from '../components/BackToTop.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'DUC Essen - Deutscher Unterwasserclub Essen e.V.',
  description = 'DUC Essen - Dein Verein für Tauchen, Apnoe, Freediving und Flossenschwimmen in Essen. Training Di 20:00 & Do 20:15 im Stadtbad Nord-Ost. Kostenloses Probetraining!',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <SeoHead title={title} description={description} />

    <!--
      Klaro Privacy Manager — Cookie/Consent-Banner.
      `is:inline` damit Astro nichts deferred/bundleled; Reihenfolge wichtig:
      Config zuerst, dann das Klaro-Script.
    -->
    <script is:inline defer src={pathTo('klaro/klaro-config.js')}></script>
    <script is:inline defer data-config="klaroConfig" src={pathTo('klaro/klaro.js')}></script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Zum Hauptinhalt springen</a>
    <Bubbles />
    <slot />
    <BackToTop />

    <script>
      import { initLayout } from '../scripts/layout';
      initLayout();
    </script>
  </body>
</html>
